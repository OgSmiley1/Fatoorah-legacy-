    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "jest": "^29.7.0",
    "tailwindcss": "^4.1.14",
    "ts-jest": "^29.4.9",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.(js|ts)$": "$1"
    }
  }
}
