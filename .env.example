# ── Required ───────────────────────────────────────────────────────────────────

# Session encryption key. Generate one: openssl rand -base64 32
SESSION_SECRET=

# Telegram bot token. Create a free bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# ── AI Providers (zero-cost free tiers) ────────────────────────────────────────

# PRIMARY AI: Google Gemini Flash 2.0 (free tier)
# Get key: https://aistudio.google.com  — no billing required
# Free limits: 1,500 requests/day, 15 RPM
GEMINI_API_KEY=

# FALLBACK AI: Groq — auto-used when Gemini is rate-limited or unavailable
# Get key: https://console.groq.com  — no billing required
# Free limits: 14,400 requests/day, Llama 3.3 70B model
GROQ_API_KEY=

# ── Search Options ─────────────────────────────────────────────────────────────

# Enable direct Google.com scraping (default: false)
# Set to true only if needed — DuckDuckGo covers most search needs without this.
# Warning: Google scraping may violate ToS and is frequently blocked.
USE_GOOGLE_SCRAPING=false

# ── Optional / Production ──────────────────────────────────────────────────────

# CORS origin for Socket.io. Restrict in production to your domain.
ALLOWED_ORIGIN=http://localhost:3000

# Set to "production" when deploying. Controls Vite HMR and static file serving.
NODE_ENV=development
