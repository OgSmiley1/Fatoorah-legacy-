# ── Required ────────────────────────────────────────────────────────────────────

# Session encryption key. Generate one: openssl rand -base64 32
SESSION_SECRET=

# Telegram bot token. Create a free bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# ── AI: Google Gemini (Primary — free tier) ─────────────────────────────────────
# Get keys at: https://aistudio.google.com — no billing required
# Free limits: 1,500 requests/day per key, 15 RPM
# Using two keys doubles effective daily limit to 3,000 req/day

GEMINI_API_KEY=
GEMINI_API_KEY_2=   # Optional second key — auto-used when key 1 is rate-limited

# ── AI: xAI Grok (Fallback — auto-used when Gemini is unavailable) ──────────────
# Get key at: https://console.x.ai
# Model: grok-4-1-fast (OpenAI-compatible API at api.x.ai)

GROK_API_KEY=

# ── AI: Groq (Last-resort fallback) ─────────────────────────────────────────────
# Get key at: https://console.groq.com — free tier, 14,400 req/day
# Model: llama-3.3-70b-versatile

GROQ_API_KEY=

# ── Search ──────────────────────────────────────────────────────────────────────

# Enable direct Google.com scraping (default: false)
# DuckDuckGo handles search without this. Google scraping is fragile and may violate ToS.
USE_GOOGLE_SCRAPING=false

# ── App ─────────────────────────────────────────────────────────────────────────

# Restrict Socket.io CORS in production to your actual domain
ALLOWED_ORIGIN=http://localhost:3000

# Set to "production" when deploying
NODE_ENV=development

# ── WhatsApp Bot ─────────────────────────────────────────────────────────────
# Path to store WhatsApp session (persist across restarts)
# On Railway: set to /data/wa_session (mount persistent volume at /data)
WA_SESSION_PATH=./wa_session

# Enable the whatsapp-web.js bot. Requires Chromium in the container.
# The Railway Dockerfile already installs chromium at /usr/bin/chromium.
ENABLE_WHATSAPP=false

# ── Database ─────────────────────────────────────────────────────────────────
# Path to SQLite database file
# On Railway: set to /data/wizard.db (mount persistent volume at /data)
DB_PATH=./wizard.db

# ── Browser (Playwright + whatsapp-web.js) ───────────────────────────────────
# Set automatically by the Dockerfile. Override only if Chromium lives elsewhere.
PLAYWRIGHT_EXECUTABLE_PATH=/usr/bin/chromium
CHROME_PATH=/usr/bin/chromium

# ── MyFatoorah webhook ───────────────────────────────────────────────────────
# Optional. If set, /api/webhooks/myfatoorah verifies the X-MyFatoorah-Signature
# HMAC-SHA256 against the raw body. Leave blank to accept unsigned webhooks.
WEBHOOK_SECRET=
