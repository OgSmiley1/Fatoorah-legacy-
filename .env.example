# SESSION_SECRET: A random string for session encryption
SESSION_SECRET=

# TELEGRAM_BOT_TOKEN: Required for Telegram remote control.
TELEGRAM_BOT_TOKEN=

# --- AI Search Sources (all optional, each enables an additional search engine) ---

# GEMINI_API_KEY: Google Gemini AI with Google Search grounding
# Free at: https://aistudio.google.com/
GEMINI_API_KEY=

# PPLX_API_KEY: Perplexity AI with sonar web-search model
# Free tier at: https://docs.perplexity.ai/
PPLX_API_KEY=

# XAI_API_KEY: Grok AI (xAI) with web search capabilities
# Free tier at: https://console.x.ai/
XAI_API_KEY=

# OLLAMA_URL: Local Ollama instance for free unlimited AI script generation
# Default: http://localhost:11434
# Install Ollama: https://ollama.ai/
OLLAMA_URL=

# OLLAMA_MODEL: Which Ollama model to use for script generation
# Default: llama3.2
OLLAMA_MODEL=
